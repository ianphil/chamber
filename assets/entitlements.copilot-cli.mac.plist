<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!--
      Entitlements for the bundled @github/copilot CLI on macOS.

      The CLI is a Node.js Single Executable Application (SEA). Under
      hardened runtime, V8's JIT requires both an executable memory
      allocation entitlement and the ability to load unsigned shared
      libraries that the SEA loader resolves at startup. Without these,
      the kernel SIGKILLs the process immediately on launch and it
      exits with code 1 producing no stdout/stderr — surfacing as
      "CLI server exited unexpectedly with code 1" in Chamber.

      These match the entitlements applied by @github when shipping
      the npm package binary directly. Re-applied here because the
      Chamber macOS signing pass would otherwise overwrite them with
      electron-osx-sign's default entitlements (audio, bluetooth,
      camera, etc.) which are appropriate for the Electron app but
      not for a bundled Node SEA tool.
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
  </dict>
</plist>
